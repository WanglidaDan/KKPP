PORT=3000
TIMEZONE=Asia/Shanghai
MEMORY_WINDOW=12
MODEL_REQUEST_TIMEOUT_MS=45000

# Current provider: Qwen / DashScope
DASHSCOPE_API_KEY=your_dashscope_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEFAULT_MODEL=qwen-plus
COMPLEX_MODEL=qwen-max

# Restrict browser origins in production, comma separated
CORS_ORIGINS=https://your-app-domain.com,https://www.your-app-domain.com

# Optional high-accuracy transcription
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
